{
  "name": "pi-mono-ext-ollama",
  "version": "0.1.0",
  "description": "Pi extension for interacting with Ollama models locally",
  "author": "",
  "license": "Apache-2.0",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "commands/**/*.ts",
    "tools/**/*.ts",
    "*.ts",
    "*.json"
  ],
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "node --experimental-strip-types --test test/unit/*.test.ts",
    "test:integration": "node --experimental-transform-types --import ./test/support/register-loader.mjs --test test/integration/*.test.ts",
    "test:all": "npm run test:unit && npm run test:integration"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@mariozechner/pi-tui": "^0.73.1"
  },
  "dependencies": {
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@mariozechner/pi-tui": "^0.73.1",
    "typescript": "^6.0.3"
  }
}
